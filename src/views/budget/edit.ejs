<%- include("../partials/header") %>

<div class="app">
  <%- include("../partials/appSidebar") %>

  <div class="app-main">
    <%- include("../partials/topbar", { pageTitle: "Edit Budget" }) %>

    <main class="content">
      <section class="card">
        <div class="card-header">
          <div>
            <h2>Edit Budget</h2>
            <p>Update this monthly spending limit.</p>
          </div>
        </div>

        <form
          action="/budget/<%= budget.budget_id %>/edit"
          method="POST"
          class="form-grid"
          novalidate
        >
          <div class="form-group">
            <label for="categoryId">Category</label>

            <select id="categoryId" name="categoryId" required>
              <% categories.forEach(category => { %>
                <option
                  value="<%= category.category_id %>"
                  <%= category.category_id === budget.category_id ? "selected" : "" %>
                >
                  <%= category.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="month">Month</label>

            <select id="month" name="month" required>
              <% const monthNames = [
                "January",
                "February",
                "March",
                "April",
                "May",
                "June",
                "July",
                "August",
                "September",
                "October",
                "November",
                "December"
              ]; %>

              <% monthNames.forEach((monthName, index) => { %>
                <option
                  value="<%= index + 1 %>"
                  <%= budget.month === index + 1 ? "selected" : "" %>
                >
                  <%= monthName %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="year">Year</label>

            <input
              type="number"
              id="year"
              name="year"
              min="2020"
              max="2100"
              value="<%= budget.year %>"
              required
            >
          </div>

          <div class="form-group">
            <label for="amount">Budget Amount</label>

            <input
              type="number"
              id="amount"
              name="amount"
              min="0.01"
              step="0.01"
              value="<%= budget.amount %>"
              required
            >
          </div>

          <div class="actions">
            <button type="submit" class="btn btn-primary">
              Save Changes
            </button>

            <a href="/budget" class="btn btn-secondary">
              Cancel
            </a>
          </div>
        </form>
      </section>
    </main>
  </div>
</div>

<%- include("../partials/footer") %>