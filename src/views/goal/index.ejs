<%- include("../partials/header") %>

<div class="app">
  <%- include("../partials/appSidebar") %>

  <div class="app-main">
    <%- include("../partials/topbar", { pageTitle: "Goals" }) %>

    <main class="content">
      <div class="page-header">
        <div>
          <h2>Savings Goals</h2>
          <p>Create goals and track your progress over time.</p>
        </div>
      </div>

      <section class="card">
        <h3>Create Goal</h3>

        <form action="/goal" method="POST" class="form-grid" novalidate>
          <div class="form-group">
            <label for="name">Goal Name</label>
            <input
              type="text"
              id="name"
              name="name"
              maxlength="155"
              required
            >
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              maxlength="500"
            ></textarea>
          </div>

          <div class="form-group">
            <label for="targetAmount">Target Amount</label>
            <input
              type="number"
              id="targetAmount"
              name="targetAmount"
              min="0.01"
              step="0.01"
              required
            >
          </div>

          <div class="form-group">
            <label for="targetDate">Target Date</label>
            <input
              type="date"
              id="targetDate"
              name="targetDate"
              required
            >
          </div>

          <button type="submit" class="btn btn-primary">
            Create Goal
          </button>
        </form>
      </section>

      <section class="goal-grid">
        <% if (goals.length === 0) { %>
          <article class="card empty-state">
            <p>No goals created yet.</p>
          </article>
        <% } %>

        <% goals.forEach(goal => { %>
          <article class="card goal-card">
            <div class="goal-card-header">
              <div>
                <h3><%= goal.name %></h3>
                <p><%= goal.description || "No description" %></p>
              </div>

              <span class="badge">
                <%= goal.status %>
              </span>
            </div>

            <div class="goal-values">
              <strong>
                $<%= goal.current_amount.toFixed(2) %>
              </strong>

              <span>
                of $<%= goal.target_amount.toFixed(2) %>
              </span>
            </div>

            <div
              class="progress-track"
              role="progressbar"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="<%= Math.round(goal.percentage) %>"
            >
              <div
                class="progress-fill"
                style="width: <%= goal.percentage %>%"
              ></div>
            </div>

            <p class="goal-percentage">
              <%= Math.round(goal.percentage) %>% complete
            </p>

            <form
              action="/goal/<%= goal.goal_id %>/contributions"
              method="POST"
              class="form-grid contribution-form"
              novalidate
            >
              <div class="form-group">
                <label for="amount-<%= goal.goal_id %>">
                  Add Contribution
                </label>

                <input
                  type="number"
                  id="amount-<%= goal.goal_id %>"
                  name="amount"
                  min="0.01"
                  step="0.01"
                  required
                >
              </div>

              <div class="form-group">
                <label for="note-<%= goal.goal_id %>">Note</label>

                <input
                  type="text"
                  id="note-<%= goal.goal_id %>"
                  name="note"
                  maxlength="255"
                >
              </div>

              <button type="submit" class="btn btn-primary">
                Add Contribution
              </button>
            </form>

            <div class="actions">
              <a
                href="/goal/<%= goal.goal_id %>/edit"
                class="btn btn-secondary"
              >
                Edit
              </a>

              <form
                action="/goal/<%= goal.goal_id %>/delete"
                method="POST"
                class="inline-form"
              >
                <button type="submit" class="btn btn-danger">
                  Delete
                </button>
              </form>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
  </div>
</div>

<%- include("../partials/footer") %>