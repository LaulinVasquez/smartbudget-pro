<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main>
  <h1>Welcome back, <%= user.firstName %></h1>

  <section>
    <article>
      <h2>Current Balance</h2>
      <p>$<%= Number(summary.current_balance).toFixed(2) %></p>
    </article>

    <article>
      <h2>Total Income</h2>
      <p>$<%= Number(summary.total_income).toFixed(2) %></p>
    </article>

    <article>
      <h2>Total Expenses</h2>
      <p>$<%= Number(summary.total_expenses).toFixed(2) %></p>
    </article>
  </section>

  <section>
    <h2>Recent Transactions</h2>

    <% if (transactions.length === 0) { %>
      <p>No transactions yet.</p>
      <a href="/transaction">Add your first transaction</a>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Category</th>
            <th>Description</th>
            <th>Type</th>
            <th>Amount</th>
          </tr>
        </thead>

        <tbody>
          <% transactions.forEach(transaction => { %>
            <tr>
              <td><%= transaction.transaction_date.toISOString().slice(0, 10) %></td>
              <td><%= transaction.category_name || "Uncategorized" %></td>
              <td><%= transaction.description || "-" %></td>
              <td><%= transaction.transaction_type %></td>
              <td>
                <% if (transaction.transaction_type === "income") { %>
                  +$<%= Number(transaction.amount).toFixed(2) %>
                <% } else { %>
                  -$<%= Number(transaction.amount).toFixed(2) %>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <p>
        <a href="/transaction">View all transactions</a>
      </p>
    <% } %>
  </section>
</main>

<%- include("../partials/footer") %>