<%- include("../partials/header") %>

<div class="app">
  <%- include("../partials/appSidebar") %>

  <div class="app-main">
    <%- include("../partials/topbar", { pageTitle: "Advisor Request" }) %>

    <main class="content">
      <a href="/advisor" class="link back-link">
        &larr; Back to Requests
      </a>

      <section class="card">
        <div class="request-header">
          <div>
            <span class="badge badge-<%= request.status %>">
              <%= request.status.replaceAll("_", " ") %>
            </span>

            <h2><%= request.subject %></h2>

            <p>
              Review the request details and update its current status.
            </p>
          </div>
        </div>
      </section>

      <section class="card">
        <div class="card-header">
          <div>
            <h3>Client Information</h3>
            <p>Information about the user who submitted this request.</p>
          </div>
        </div>

        <dl class="info-grid">
          <div>
            <dt>Name</dt>

            <dd>
              <%= request.user_first_name %>
              <%= request.user_last_name %>
            </dd>
          </div>

          <div>
            <dt>Email</dt>
            <dd><%= request.user_email %></dd>
          </div>

          <div>
            <dt>Submitted</dt>

            <dd>
              <%= new Date(request.created_at).toLocaleString() %>
            </dd>
          </div>
        </dl>
      </section>

      <section class="card">
        <div class="card-header">
          <div>
            <h3>Request Message</h3>
            <p>The user’s original message.</p>
          </div>
        </div>

        <div class="request-body">
          <%= request.message %>
        </div>
      </section>

      <section class="card">
        <div class="card-header">
          <div>
            <h3>Manage Request</h3>
            <p>Accept the request or update its progress.</p>
          </div>
        </div>

        <% if (request.advisor_id === null) { %>
          <form
            action="/advisor/requests/<%= request.request_id %>/accept"
            method="POST"
          >
            <button type="submit" class="btn btn-primary">
              Accept Request
            </button>
          </form>

        <% } else if (
          request.status !== "completed" &&
          request.status !== "rejected"
        ) { %>
          <form
            action="/advisor/requests/<%= request.request_id %>/status"
            method="POST"
            class="form-grid request-status-form"
            novalidate
          >
            <div class="form-group">
              <label for="status">Request Status</label>

              <select id="status" name="status" required>
                <option
                  value="reviewing"
                  <%= request.status === "reviewing" ? "selected" : "" %>
                >
                  Reviewing
                </option>

                <option
                  value="accepted"
                  <%= request.status === "accepted" ? "selected" : "" %>
                >
                  Accepted
                </option>

                <option
                  value="completed"
                  <%= request.status === "completed" ? "selected" : "" %>
                >
                  Completed
                </option>

                <option
                  value="rejected"
                  <%= request.status === "rejected" ? "selected" : "" %>
                >
                  Rejected
                </option>
              </select>
            </div>

            <button type="submit" class="btn btn-primary">
              Update Status
            </button>
          </form>

        <% } else { %>
          <div class="request-closed">
            <p>
              This request is closed with the status
              <strong>
                <%= request.status.replaceAll("_", " ") %>
              </strong>.
            </p>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</div>

<%- include("../partials/footer") %>