<header>
  <h1>SmartBudget Pro</h1>

  <nav>
    <a href="/">Home</a>
    <a href="/about">About</a>

    <% if (!isLoggedIn) { %>
    <a href="/login">Login</a>
    <a href="/register">Register</a>
    <% } else { %>
    <% if (user.role === "admin") { %>
    <a href="/admin">Admin Dashboard</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/categories">Categories</a>
    <% } %>

    <% if (user.role === "advisor") { %>
    <a href="/advisor"> Advisor Dashboard</a>
    <a href="/advisor/requests"> Requests</a>
    <% } %>

    <% if (user.role === "user") { %>
    <a href="/dashboard">Dashboard</a>
    <a href="/transaction">Transactions</a>
    <a href="/budgets">Budgets</a>
    <a href="/goals">Goals</a>
    <% } %>
    <form action="/logout" method="POST" style="display:inline;">
      <button type="submit">Logout</button>
    </form>
    <% } %>

  </nav>

  <hr>
</header>

<%
const messages =
    typeof flashMessages !== "undefined"
        ? flashMessages
        : {
            success: [],
            error: [],
            warning: [],
            info: [],
        };

const hasMessages = Object.values(messages).some(
    list => list.length > 0
);
%>

<% if (hasMessages) { %>
<div class="flash-messages">

  <% Object.entries(messages).forEach(([type, list]) => { %>

  <% list.forEach(message => { %>

  <div class="flash <%= type %>">
    <%= message %>
  </div>

  <% }) %>

  <% }) %>

</div>
<% } %>