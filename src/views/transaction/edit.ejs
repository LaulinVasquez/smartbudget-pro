<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main>
    <h1>Edit Transaction</h1>

    <form action="/transaction/<%= transaction.transaction_id %>/edit" method="POST" novalidate>
        <div>
            <label for="transactionType">Type</label>
            <select id="transactionType" name="transactionType" required>
                <option value="income" <%= transaction.transaction_type === "income" ? "selected" : "" %>>
                    Income
                </option>

                <option value="expense" <%= transaction.transaction_type === "expense" ? "selected" : "" %>>
                    Expense
                </option>
            </select>
        </div>

        <div>
            <label for="categoryId">Category</label>
            <select id="categoryId" name="categoryId" required>
                <% categories.forEach(category => { %>
                    <option
                        value="<%= category.category_id %>"
                        <%= category.category_id === transaction.category_id ? "selected" : "" %>
                    >
                        <%= category.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div>
            <label for="amount">Amount</label>
            <input
                type="number"
                id="amount"
                name="amount"
                step="0.01"
                min="0.01"
                value="<%= transaction.amount %>"
                required
            >
        </div>

        <div>
            <label for="transactionDate">Date</label>
            <input
                type="date"
                id="transactionDate"
                name="transactionDate"
                value="<%= transaction.transaction_date.toISOString().slice(0, 10) %>"
                required
            >
        </div>

        <div>
            <label for="description">Description</label>
            <textarea
                id="description"
                name="description"
                maxlength="255"
            ><%= transaction.description || "" %></textarea>
        </div>

        <button type="submit">Save Changes</button>
    </form>

    <p>
        <a href="/transaction">Back to Transactions</a>
    </p>
</main>

<%- include("../partials/footer") %>