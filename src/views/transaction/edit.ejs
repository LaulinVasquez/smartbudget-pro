<%- include("../partials/header") %>

<div class="app">
    <%- include("../partials/appSidebar") %>
    <div class="app-main">
        <%- include("../partials/topbar", { pageTitle: "Transactions" }) %>
        <main class="content">
            <div class="page-header">
                <h1>Edit Transaction</h1>
            <div>
            <form action="/transaction/<%= transaction.transaction_id %>/edit" method="POST" class="form-grid" novalidate>
                <div class="form-group">
                    <label for="transactionType">Type</label>
                    <select id="transactionType" name="transactionType" required>
                        <option value="income" <%= transaction.transaction_type === "income" ? "selected" : "" %>>
                            Income
                        </option>

                        <option value="expense" <%= transaction.transaction_type === "expense" ? "selected" : "" %>>
                            Expense
                        </option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="categoryId">Category</label>
                    <select id="categoryId" name="categoryId" required>
                        <% categories.forEach(category => { %>
                            <option
                                value="<%= category.category_id %>"
                                <%= category.category_id === transaction.category_id ? "selected" : "" %>
                            >
                                <%= category.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="amount">Amount</label>
                    <input
                        type="number"
                        id="amount"
                        name="amount"
                        step="0.01"
                        min="0.01"
                        value="<%= transaction.amount %>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="transactionDate">Date</label>
                    <input
                        type="date"
                        id="transactionDate"
                        name="transactionDate"
                        value="<%= transaction.transaction_date.toISOString().slice(0, 10) %>"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea
                        id="description"
                        name="description"
                        maxlength="255"
                    ><%= transaction.description || "" %></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>

            <p>
                <a href="/transaction" class="btn btn-secundary">Back to Transactions</a>
            </p>
        </main>
    </div>
</div>

<%- include("../partials/footer") %>